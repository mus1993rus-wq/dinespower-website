# Copy this file to .env.local and fill in values you need.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# When unset, the Analytics component renders nothing and no scripts load.
# When set, scripts load only AFTER the user accepts cookies.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public canonical site URL, used for sitemap/robots/OG tags.
# No trailing slash. Example: https://dinespower.info
NEXT_PUBLIC_SITE_URL=https://dinespower.info
